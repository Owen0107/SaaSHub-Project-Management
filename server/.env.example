# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/saashub
# Or for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/saashub?retryWrites=true&w=majority

# JWT Secrets (Must be at least 32 characters)
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars

# Server Port
PORT=5000

# Environment (development / production)
NODE_ENV=development

# Client URL (for CORS) - Use http://localhost if using Docker
CLIENT_URL=http://localhost:5173

# GitHub Webhook (Optional, for auto status updates)
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
